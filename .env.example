HTTP_ADDR=:8080
ALLOW_ORIGIN=http://localhost:5173

# Use your Windows-accessible Prometheus URL during local development.
# Example: http://localhost:9090
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT_SECONDS=10
PROMETHEUS_SMOKE_QUERY=up

# Local Docker Compose Postgres. Replace with Supabase connection string when supplied.
DATABASE_URL=postgres://monitoring:monitoring@localhost:5432/monitoring?sslmode=disable
JWT_SECRET=change-me-in-real-deployments
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=viewer123
LOG_LEVEL=info
